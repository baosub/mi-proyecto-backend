{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist", //Donde se guardaran los archivos transpilados
        "rootDir": "./src" //Elegimos cual es la carpeta root
    },
    "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
